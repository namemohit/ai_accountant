# YantrAI Accountant — environment variables template
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# In production (Cloud Run) the same vars are set as service env config
# (see `gcloud run services describe yantrai-accounting --format='value(spec.template.spec.containers[0].env)'`).
#
# Code (`db.py:_require_env`) FAILS FAST if a required var is missing — no in-code
# fallback secrets. If you ever see "Required env var 'X' is not set", add X here.

# ── REQUIRED — server.py + db.py + backfill_embeddings.py ────────────────────

# Supabase Postgres URL (pooler — IPv4 compatible).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DB_URL=

# Google Gemini API key (for parsing, embeddings, chat).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── REQUIRED — server.py (Supabase user-auth) ────────────────────────────────

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── REQUIRED — server.py (Razorpay billing) ──────────────────────────────────

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── OPTIONAL — server.py ─────────────────────────────────────────────────────

# Google Places API key (used by /api/leads/* — leave empty to disable).
GOOGLE_PLACES_API_KEY=

# Local Tally Prime URL. Defaults to http://localhost:9000 if unset.
TALLY_URL=

# Enforce Supabase JWT auth on non-whitelisted routes. "0" = off, "1" = on.
# Off by default locally; ON in Cloud Run.
AUTH_ENFORCE=

# ── OPTIONAL — agent_dump/ demo scripts only ─────────────────────────────────

# For drive_sync.py / headless_agent_demo.py. Demo scripts fail fast without these.
YANTRAI_TEST_USERNAME=
YANTRAI_TEST_PASSWORD=
