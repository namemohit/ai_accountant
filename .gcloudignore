# Sprint 33 — keep secrets, uploads, and large binaries out of the Cloud Run image
.git/
.gitignore
__pycache__/
*.pyc
*.log
.env
.claude/

# Local credential temp files (NEVER deploy)
C:*auth*.json
*auth.json
*auth_*.json

# User-uploaded files (regenerated at runtime; not part of the app)
static/uploads/

# Archived agent binaries + PyInstaller build artifacts (17MB+ each)
agent_dump/
tally_agent/build/
build/
dist/
*.exe

# Sprint 34 — EXCEPT the live agent binary: it MUST ship in the Cloud Run
# image so /tally_bridge_agent/download serves the latest .exe in production.
!tally_agent/dist/
!tally_agent/dist/tally_bridge_agent.exe

# One-shot backfill / debug scripts (not needed in prod image)
backfill_*.py
debug_*.py
run_agent_once.py
check_outbox.py
migrate_users_v2.py
run_embeddings.py
